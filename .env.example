SECRET_KEY=your-secret-key-here-change-this-in-production
DATABASE_URL=sqlite:///sjec_publications.db
UPLOAD_FOLDER=uploads/publications
MAX_CONTENT_LENGTH=26214400
ALLOWED_EXTENSIONS=pdf

# Email Configuration (REQUIRED for email functionality)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@sjec.ac.in
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=noreply@sjec.ac.in

# Notes:
# 1. Copy this file to .env and fill in actual values
# 2. Never commit .env file to version control
# 3. For Gmail: Enable 2FA and generate App Password
# 4. For institutional SMTP: Contact IT department
